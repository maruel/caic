# caic environment configuration
# Copy to ~/.config/caic/caic.env and edit as needed.
# The systemd service (caic.service) loads this file automatically.

# HTTP listen address for the web UI.
CAIC_HTTP=:8005

# Parent directory containing git repositories managed by caic.
CAIC_ROOT=~/src

# Log level: debug, info, warn, error.
#CAIC_LOG_LEVEL=info

# Gemini API key — used for the Gemini agent backend.
# Obtain from https://aistudio.google.com/app/apikey
#GEMINI_API_KEY=

# Tailscale API key — used for Tailscale integration.
# Obtain from https://login.tailscale.com/admin/settings/keys
#TAILSCALE_API_KEY=

# OAuth login — set CAIC_EXTERNAL_URL to enable; then configure at least one provider.
# When OAuth is enabled, the logged-in user's token is used for PR/MR creation and CI monitoring,
# so GITHUB_TOKEN / GITLAB_TOKEN below are not needed.
# See SELF_HOSTING.md for instructions on creating OAuth apps.
#CAIC_EXTERNAL_URL=https://caic.example.com
#GITHUB_OAUTH_CLIENT_ID=
#GITHUB_OAUTH_CLIENT_SECRET=
#GITLAB_OAUTH_CLIENT_ID=
#GITLAB_OAUTH_CLIENT_SECRET=
#GITLAB_URL=https://gitlab.com

# GitHub personal access token — only needed when GitHub OAuth login is NOT configured.
# Enables PR creation and CI monitoring for github.com repos in headless / single-user deployments.
# Create a fine-grained token at https://github.com/settings/personal-access-tokens/new?name=caic&description=caic+PR+creation+and+CI+monitoring&pull_requests=write&checks=read&expires_in=365
#GITHUB_TOKEN=

# GitLab personal access token — only needed when GitLab OAuth login is NOT configured.
# Enables MR creation and CI monitoring for gitlab.com repos in headless / single-user deployments.
# Create a token with "api" scope at https://gitlab.com/-/user_settings/personal_access_tokens?name=caic&scopes=api
#GITLAB_TOKEN=

# AI provider for LLM features (title generation, commit descriptions).
# e.g. anthropic, gemini, openaichat, etc. See https://pkg.go.dev/github.com/maruel/genai/providers.
# Don't forget to set the corresponding FOO_API_KEY.
#CAIC_LLM_PROVIDER=

# Model name for LLM features (e.g. claude-haiku-4-5-20251001).
#CAIC_LLM_MODEL=
