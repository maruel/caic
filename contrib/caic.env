# caic environment configuration
# Copy to ~/.config/caic/caic.env and edit as needed.
# The systemd service (caic.service) loads this file automatically.

# ── Core ─────────────────────────────────────────────────────────────────────

# HTTP listen address for the web UI. (required)
CAIC_HTTP=:8005

# Parent directory containing git repositories managed by caic. (required)
CAIC_ROOT=~/src

# Log level: debug, info, warn, error.
#CAIC_LOG_LEVEL=info

# ── LLM features (title generation, commit descriptions) ─────────────────────

# Provider: anthropic, gemini, openaichat, etc.
# See https://pkg.go.dev/github.com/maruel/genai/providers
#CAIC_LLM_PROVIDER=
#CAIC_LLM_MODEL=

# ── GitHub ────────────────────────────────────────────────────────────────────

# PAT — single-user / headless. Mutually exclusive with GitHub OAuth.
# Create at https://github.com/settings/personal-access-tokens/new?name=my+caic+instance&description=caic+PR+creation+and+CI+monitoring&pull_requests=write&checks=read&expires_in=365
# Required permissions: pull_requests:write, checks:read
#GITHUB_TOKEN=

# OAuth — multi-user login. Mutually exclusive with GITHUB_TOKEN.
# See SELF_HOSTING.md for OAuth app setup instructions.
#GITHUB_OAUTH_CLIENT_ID=
#GITHUB_OAUTH_CLIENT_SECRET=
#GITHUB_OAUTH_ALLOWED_USERS=alice,bob

# GitHub App — org-wide webhooks and automatic task creation.
# Layered on top of PAT or OAuth; not mutually exclusive with either.
# Create at https://github.com/settings/apps/new?name=my+caic+instance&webhook_active=true&issues=write&pull_requests=write&checks=read&events[]=issues&events[]=pull_request&events[]=issue_comment&events[]=check_suite
# See SELF_HOSTING.md for GitHub App setup instructions.
#GITHUB_APP_ID=
#GITHUB_APP_PRIVATE_KEY_PEM=private-key.pem
# Generate with: openssl rand -hex 32
#GITHUB_WEBHOOK_SECRET=
# Comma-separated GitHub owners/orgs allowed to install the app. Installs from
# other accounts are rejected automatically. Leave unset to allow all installs.
#GITHUB_APP_ALLOWED_OWNERS=my-org,my-username

# ── GitLab ────────────────────────────────────────────────────────────────────

# PAT — single-user / headless. Mutually exclusive with GitLab OAuth.
# Create at https://gitlab.com/-/user_settings/personal_access_tokens?name=my+caic+instance&scopes=api
# Required scope: api
#GITLAB_TOKEN=

# OAuth — multi-user login. Mutually exclusive with GITLAB_TOKEN.
# See SELF_HOSTING.md for OAuth app setup instructions.
#GITLAB_OAUTH_CLIENT_ID=
#GITLAB_OAUTH_CLIENT_SECRET=
#GITLAB_OAUTH_ALLOWED_USERS=alice,bob

# GitLab instance URL. Default: https://gitlab.com
#GITLAB_URL=https://gitlab.com

# Webhook CI — real-time pipeline status. See SELF_HOSTING.md § Webhook CI.
# Generate with: openssl rand -hex 32
#GITLAB_WEBHOOK_SECRET=

# ── Exposure (OAuth login and webhooks) ───────────────────────────────────────

# Public base URL. Required for OAuth login and GitHub webhooks.
# Can be a public HTTPS domain or a Tailscale Funnel / serve URL.
# See SELF_HOSTING.md § HTTPS exposure options.
#CAIC_EXTERNAL_URL=https://caic.example.com or https://caic.my-tailnet.ts.net

# ── Agents ────────────────────────────────────────────────────────────────────

# Gemini API key — required for the Gemini Live voice agent.
# Obtain from https://aistudio.google.com/app/apikey
#GEMINI_API_KEY=

# Tailscale API key — required for Tailscale ephemeral node.
# Obtain from https://login.tailscale.com/admin/settings/keys
#TAILSCALE_API_KEY=
